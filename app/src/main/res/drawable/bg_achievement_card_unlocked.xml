<?xml version="1.0" encoding="utf-8"?>
<!-- Unlocked achievement card — teal bottom border -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/colorCard"/>
            <corners android:radius="16dp"/>
        </shape>
    </item>
    <item android:top="0dp" android:left="0dp" android:right="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/colorCard"/>
            <corners android:radius="16dp"/>
            <stroke android:width="0dp" android:color="@color/colorBorder"/>
        </shape>
    </item>
</layer-list>

