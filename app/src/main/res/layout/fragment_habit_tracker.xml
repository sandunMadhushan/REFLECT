<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ht_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbarStyle="outsideInset">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <!-- ── Header Row ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ht_title"
                        android:textColor="@color/ht_date_text"
                        android:textSize="26sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/ht_subtitle"
                        android:textColor="@color/ht_day_text"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btn_settings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="@string/profile_section_preferences"
                    android:padding="8dp"
                    app:tint="@color/ht_day_text" />
            </RelativeLayout>

            <!-- ── Calendar Card ── -->
            <LinearLayout
                android:id="@+id/ll_calendar_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_ht_calendar_card"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Month navigation row -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <ImageButton
                        android:id="@+id/btn_prev_month"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_arrow_back"
                        android:contentDescription="@string/ht_prev_month"
                        android:padding="6dp"
                        app:tint="@color/ht_day_text" />

                    <TextView
                        android:id="@+id/tv_month_year"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerInParent="true"
                        android:text=""
                        android:textColor="@color/ht_date_text"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btn_next_month"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_arrow_forward"
                        android:contentDescription="@string/ht_next_month"
                        android:padding="6dp"
                        app:tint="@color/ht_day_text" />
                </RelativeLayout>

                <!-- Day labels row (S M T W T F S) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_sun" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_mon_label" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_tue_label" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_wed_label" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_thu_label" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_fri_label" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center"
                        android:text="@string/ht_day_sat_label" android:textColor="@color/ht_day_text"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Week dates row -->
                <LinearLayout
                    android:id="@+id/ll_week_dates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false">

                    <FrameLayout android:id="@+id/day_0"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_0"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_date_text"
                            android:textSize="13sp" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/day_1"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_1"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_date_text"
                            android:textSize="13sp" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/day_2"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_2"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_date_text"
                            android:textSize="13sp" />
                    </FrameLayout>

                    <!-- Today — selected with teal circle -->
                    <FrameLayout android:id="@+id/day_3"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_3"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_selected_day_text"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/day_4"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_4"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_date_text"
                            android:textSize="13sp" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/day_5"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_5"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_date_text"
                            android:textSize="13sp" />
                    </FrameLayout>

                    <FrameLayout android:id="@+id/day_6"
                        android:layout_width="0dp" android:layout_height="40dp"
                        android:layout_weight="1" android:clickable="true"
                        android:focusable="true">
                        <TextView android:id="@+id/tv_day_6"
                            android:layout_width="36dp" android:layout_height="36dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:text=""
                            android:textColor="@color/ht_date_text"
                            android:textSize="13sp" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── Stats Row: Current Streak | Completion ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginBottom="24dp">

                <!-- Current Streak card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ht_stat_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginEnd="8dp">

                    <!-- Icon + Label row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_fire"
                            android:contentDescription="@null"
                            android:layout_marginEnd="6dp"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ht_current_streak"
                            android:textColor="@color/ht_day_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_streak_days"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/ht_date_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Completion card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_ht_stat_card"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginStart="8dp">

                    <!-- Icon + Label row -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_check_teal"
                            android:contentDescription="@null"
                            android:layout_marginEnd="6dp"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ht_completion"
                            android:textColor="@color/ht_day_text"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.08" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_completion_pct"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/ht_date_text"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- ── Today's Habits Header ── -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="@string/ht_today_habits"
                    android:textColor="@color/ht_date_text"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_manage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="@string/ht_manage"
                    android:textColor="@color/ht_teal"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp" />
            </RelativeLayout>

            <!-- ── Habits List (RecyclerView) ── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_habits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <!-- Empty state (shown when no habits) -->
            <TextView
                android:id="@+id/tv_empty_habits"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/ht_no_habits"
                android:textColor="@color/ht_day_text"
                android:textSize="14sp"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:padding="16dp" />

            <!-- ── Add New Habit Button ── -->
            <TextView
                android:id="@+id/btn_add_habit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_ht_add_habit_btn"
                android:gravity="center"
                android:text="@string/ht_add_new_habit"
                android:textColor="@color/ht_teal"
                android:textSize="15sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </ScrollView>
</FrameLayout>













