<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/bg_card_dark"
    android:padding="16dp"
    android:clickable="true"
    android:focusable="true">

    <!-- Icon circle -->
    <FrameLayout
        android:id="@+id/notif_icon_bg"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_circle_primary_light">
        <ImageView
            android:id="@+id/notif_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_notifications"
            app:tint="@color/primary"/>
    </FrameLayout>

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextPrimary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/notif_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:layout_marginTop="2dp"
            android:maxLines="2"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginTop="4dp"/>
    </LinearLayout>

    <!-- Unread dot -->
    <View
        android:id="@+id/notif_unread_dot"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/bg_notif_dot"
        android:visibility="gone"/>

</LinearLayout>

