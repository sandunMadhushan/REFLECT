<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorAppBg">

    <!-- ===== STICKY HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="52dp"
        android:paddingBottom="12dp"
        android:background="@color/colorAppBg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/colorTextPrimary"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@null"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress Analytics"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="26sp"
                    android:textStyle="bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your growth at a glance"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ===== TIME FILTER CHIPS ===== -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_week"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="This Week"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                android:background="@drawable/bg_filter_chip_active"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_month"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginStart="8dp"
                android:text="This Month"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:background="@drawable/bg_filter_chip_inactive"
                android:clickable="true"
                android:focusable="true"/>

            <TextView
                android:id="@+id/chip_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:layout_marginStart="8dp"
                android:text="All Time"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:background="@drawable/bg_filter_chip_inactive"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </HorizontalScrollView>

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <!-- ── HABIT COMPLETION BAR CHART CARD ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_analytics_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Habit Completion"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_habit_pct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0%"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="30sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Trend badge -->
                    <LinearLayout
                        android:id="@+id/layout_habit_trend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_circle_green"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp">
                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:rotation="-90"
                            app:tint="#16A34A"
                            android:contentDescription="@null"/>
                        <TextView
                            android:id="@+id/tv_habit_trend"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+0%"
                            android:textColor="#16A34A"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:layout_marginStart="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Bar chart -->
                <LinearLayout
                    android:id="@+id/bar_chart_container"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:baselineAligned="false">

                    <!-- 7 bars — Mon to Sun, generated in code -->
                </LinearLayout>

                <!-- Day labels row -->
                <LinearLayout
                    android:id="@+id/day_labels_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                </LinearLayout>
            </LinearLayout>

            <!-- ── 4 STAT CARDS GRID ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:baselineAligned="false">

                <!-- Left col -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <!-- Total Goals -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_analytics_card"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:elevation="2dp">
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle_primary_light"
                            android:layout_marginBottom="10dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_flag"
                                app:tint="@color/primary"
                                android:contentDescription="@null"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL GOALS"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"/>
                        <TextView
                            android:id="@+id/tv_total_goals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- In Progress -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_analytics_card"
                        android:padding="16dp"
                        android:elevation="2dp">
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_habit_icon_orange"
                            android:layout_marginBottom="10dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_fire"
                                app:tint="#F97316"
                                android:contentDescription="@null"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="IN PROGRESS"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"/>
                        <TextView
                            android:id="@+id/tv_active_goals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Right col -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- Completed -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_analytics_card"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:elevation="2dp">
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_circle_green"
                            android:layout_marginBottom="10dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_check_circle"
                                app:tint="@color/colorGreenIcon"
                                android:contentDescription="@null"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="COMPLETED"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"/>
                        <TextView
                            android:id="@+id/tv_completed_goals"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <!-- Habit Streak -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/bg_analytics_card"
                        android:padding="16dp"
                        android:elevation="2dp">
                        <FrameLayout
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_habit_icon_pink"
                            android:layout_marginBottom="10dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_favorite"
                                app:tint="#EC4899"
                                android:contentDescription="@null"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BEST STREAK"
                            android:textColor="@color/colorTextSecondary"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.08"/>
                        <TextView
                            android:id="@+id/tv_best_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 days"
                            android:textColor="@color/colorTextPrimary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ── REFLECTION STREAK CARD (gradient) ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_streak_card_gradient"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reflection Consistency"
                            android:textColor="#CCffffff"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/tv_reflection_streak"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 Reflections"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_white_alpha">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu_book"
                            android:contentDescription="@null"/>
                    </FrameLayout>
                </LinearLayout>

                <!-- Heatmap dots -->
                <LinearLayout
                    android:id="@+id/heatmap_container"
                    android:layout_width="match_parent"
                    android:layout_height="8dp"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_reflection_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keep writing every day!"
                    android:textColor="#99ffffff"
                    android:textSize="11sp"
                    android:layout_marginTop="8dp"/>
            </LinearLayout>

            <!-- ── GOAL CATEGORY BREAKDOWN (Donut + Progress Bars) ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Category Breakdown"
                android:textColor="@color/colorTextPrimary"
                android:textSize="17sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_analytics_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <!-- Donut + Legend row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <!-- Donut chart -->
                    <me.madhushan.reflect.ui.DonutChartView
                        android:id="@+id/donut_chart"
                        android:layout_width="110dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="20dp"/>

                    <!-- Legend -->
                    <LinearLayout
                        android:id="@+id/legend_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                    </LinearLayout>
                </LinearLayout>

                <!-- Progress bars per category -->
                <LinearLayout
                    android:id="@+id/category_bars_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                </LinearLayout>
            </LinearLayout>

            <!-- ── TOTAL REFLECTIONS STAT ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_analytics_card"
                android:padding="20dp"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp"
                android:elevation="2dp">

                <FrameLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_circle_primary_light">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_journal"
                        app:tint="@color/primary"
                        android:contentDescription="@null"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Reflections Written"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/tv_total_reflections"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_reflections_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="entries"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>

