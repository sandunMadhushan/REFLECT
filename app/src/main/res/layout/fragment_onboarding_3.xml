<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/colorAppBg"
    android:paddingStart="28dp"
    android:paddingEnd="28dp">

    <!-- Illustration area -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="32dp">

        <!-- Glow -->
        <View
            android:layout_width="280dp"
            android:layout_height="280dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_onboarding_glow_purple"
            android:alpha="0.4"/>

        <!-- Progress card -->
        <androidx.cardview.widget.CardView
            android:layout_width="200dp"
            android:layout_height="220dp"
            android:layout_gravity="center"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/colorCard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Trending up icon -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_purple">
                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_goals"
                            android:contentDescription="Progress"
                            app:tint="@color/colorPurpleIcon"/>
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">
                        <View android:layout_width="70dp" android:layout_height="7dp" android:background="@drawable/bg_skeleton_line" android:layout_marginBottom="5dp"/>
                        <View android:layout_width="50dp" android:layout_height="6dp" android:background="@drawable/bg_skeleton_line"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Animated bar chart -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <View android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_bar_onboarding_purple_light"/>
                    <View android:layout_width="0dp" android:layout_height="55dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_bar_onboarding_purple_light"/>
                    <View android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/bg_bar_onboarding_purple_light"/>
                    <View android:layout_width="0dp" android:layout_height="85dp" android:layout_weight="1" android:background="@drawable/bg_bar_onboarding_purple"/>
                </LinearLayout>

                <!-- +24% badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:background="@drawable/bg_circle_green"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:text="+24%"
                    android:textColor="@color/colorGreenIcon"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:fontFamily="sans-serif"
        android:letterSpacing="-0.02"
        android:text="@string/onboarding3_title"
        android:textColor="@color/colorTextPrimary"
        android:textSize="28sp"
        android:textStyle="bold"/>

    <Space android:layout_width="match_parent" android:layout_height="12dp"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingMultiplier="1.4"
        android:text="@string/onboarding3_subtitle"
        android:textColor="@color/colorTextSecondary"
        android:textSize="15sp"/>

</LinearLayout>


