<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorAppBg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:background="@color/colorCard"
        android:elevation="4dp">

        <FrameLayout
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                app:tint="@color/colorTextPrimary"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="New Reflection"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <!-- Spacer to balance back button -->
        <View android:layout_width="44dp" android:layout_height="44dp"/>
    </LinearLayout>

    <!-- Scrollable form -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- ── Title field ─────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TITLE"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_reflection_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_field"
                android:hint="e.g. Weekly Reflection"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextSecondary"
                android:textSize="15sp"
                android:padding="14dp"
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:layout_marginBottom="24dp"/>

            <!-- ── Mood ──────────────────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW ARE YOU FEELING?"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/mood_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="24dp">

                <!-- Happy -->
                <LinearLayout
                    android:id="@+id/mood_happy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:id="@+id/mood_happy_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_circle_green">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="😄"
                            android:textSize="26sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Happy"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Calm -->
                <LinearLayout
                    android:id="@+id/mood_calm"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:id="@+id/mood_calm_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_circle_blue">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="😌"
                            android:textSize="26sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Calm"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Neutral -->
                <LinearLayout
                    android:id="@+id/mood_neutral"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:id="@+id/mood_neutral_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_circle_blue">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="😐"
                            android:textSize="26sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Neutral"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Sad -->
                <LinearLayout
                    android:id="@+id/mood_sad"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:id="@+id/mood_sad_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_circle_blue">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="😔"
                            android:textSize="26sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sad"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

                <!-- Anxious -->
                <LinearLayout
                    android:id="@+id/mood_anxious"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">
                    <FrameLayout
                        android:id="@+id/mood_anxious_bg"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_circle_purple">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="😰"
                            android:textSize="26sp"/>
                    </FrameLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Anxious"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- ── Journal content ──────────────────────────────────── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JOURNAL"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_reflection_content"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@drawable/bg_input_field"
                android:hint="Write your thoughts here… What went well? What challenged you?"
                android:textColor="@color/colorTextPrimary"
                android:textColorHint="@color/colorTextSecondary"
                android:textSize="15sp"
                android:padding="14dp"
                android:gravity="top"
                android:inputType="textMultiLine|textCapSentences"
                android:layout_marginBottom="12dp"/>

            <!-- ── AI Mood Detection ──────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/ai_mood_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_primary"
                android:padding="14dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <!-- AI chip label -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🤖"
                            android:textSize="16sp"
                            android:layout_marginEnd="6dp"/>
                        <TextView
                            android:id="@+id/tv_ai_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Mood Detect"
                            android:textColor="@color/primary"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Detect button -->
                    <LinearLayout
                        android:id="@+id/btn_ai_detect"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_btn_primary"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView
                            android:id="@+id/tv_btn_detect_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/ai_detect_btn"
                            android:textColor="@color/white"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Result row -->
                <LinearLayout
                    android:id="@+id/ai_result_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Detected:"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_ai_detected_mood"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/tv_ai_confidence"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Confidence bars -->
                <LinearLayout
                    android:id="@+id/ai_bars_row"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp"
                    android:visibility="gone">

                    <!-- happy bar -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="😄 Happy" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                        <ProgressBar
                            android:id="@+id/bar_happy"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                            android:progressTint="@color/primary" android:max="100"/>
                        <TextView android:id="@+id/pct_happy" android:layout_width="36dp" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="end"/>
                    </LinearLayout>

                    <!-- calm bar -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="😌 Calm" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                        <ProgressBar
                            android:id="@+id/bar_calm"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                            android:progressTint="@color/primary" android:max="100"/>
                        <TextView android:id="@+id/pct_calm" android:layout_width="36dp" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="end"/>
                    </LinearLayout>

                    <!-- neutral bar -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="😐 Neutral" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                        <ProgressBar
                            android:id="@+id/bar_neutral"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                            android:progressTint="@color/primary" android:max="100"/>
                        <TextView android:id="@+id/pct_neutral" android:layout_width="36dp" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="end"/>
                    </LinearLayout>

                    <!-- sad bar -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="😔 Sad" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                        <ProgressBar
                            android:id="@+id/bar_sad"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                            android:progressTint="@color/primary" android:max="100"/>
                        <TextView android:id="@+id/pct_sad" android:layout_width="36dp" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="end"/>
                    </LinearLayout>

                    <!-- anxious bar -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="60dp" android:layout_height="wrap_content"
                            android:text="😰 Anxious" android:textSize="11sp" android:textColor="@color/colorTextSecondary"/>
                        <ProgressBar
                            android:id="@+id/bar_anxious"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1"
                            android:progressTint="@color/primary" android:max="100"/>
                        <TextView android:id="@+id/pct_anxious" android:layout_width="36dp" android:layout_height="wrap_content"
                            android:textSize="10sp" android:textColor="@color/colorTextSecondary" android:gravity="end"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Save button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorCard"
        android:elevation="8dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/btn_save_reflection"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_btn_primary"
            android:orientation="horizontal"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_check_circle"
                app:tint="@color/white"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Save Reflection"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>

