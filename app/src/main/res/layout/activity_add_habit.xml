<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorAppBg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:background="@color/colorAppBg">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/colorTextPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@null"/>

        <TextView
            android:id="@+id/tv_screen_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Add New Habit"
            android:textColor="@color/colorTextPrimary"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <View android:layout_width="44dp" android:layout_height="44dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Habit Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HABIT NAME"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_habit_name"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="e.g. Morning Meditation"
                    android:inputType="textCapSentences"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION / GOAL"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_habit_description"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="e.g. 15 minutes, 2 Liters"
                    android:inputType="textCapSentences"
                    android:textColor="@color/colorTextPrimary"
                    android:textColorHint="@color/colorTextSecondary"
                    android:textSize="15sp"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Icon Color Picker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ICON COLOR"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Indigo swatch -->
                <FrameLayout
                    android:id="@+id/color_indigo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="12dp">
                    <!-- Solid color circle -->
                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_indigo"/>
                    <!-- Selection ring (visible when selected) -->
                    <View
                        android:id="@+id/color_indigo_check"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_selected_ring"
                        android:visibility="visible"/>
                </FrameLayout>

                <!-- Emerald swatch -->
                <FrameLayout
                    android:id="@+id/color_emerald"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_emerald"/>
                    <View
                        android:id="@+id/color_emerald_check"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_selected_ring"
                        android:visibility="gone"/>
                </FrameLayout>

                <!-- Pink swatch -->
                <FrameLayout
                    android:id="@+id/color_pink"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_pink"/>
                    <View
                        android:id="@+id/color_pink_check"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_selected_ring"
                        android:visibility="gone"/>
                </FrameLayout>

                <!-- Orange swatch -->
                <FrameLayout
                    android:id="@+id/color_orange"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="12dp">
                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_orange"/>
                    <View
                        android:id="@+id/color_orange_check"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_selected_ring"
                        android:visibility="gone"/>
                </FrameLayout>

                <!-- Primary (violet) swatch -->
                <FrameLayout
                    android:id="@+id/color_primary"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_primary"/>
                    <View
                        android:id="@+id/color_primary_check"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_color_swatch_selected_ring"
                        android:visibility="gone"/>
                </FrameLayout>

            </LinearLayout>

            <!-- Frequency -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FREQUENCY"
                android:textColor="@color/colorTextSecondary"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/colorCard"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/freq_daily"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Daily"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/freq_weekly"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Weekly"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/freq_specific"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Specific"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Active Days -->
            <LinearLayout
                android:id="@+id/active_days_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView android:id="@+id/day_mon" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="M"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_tue" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="T"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_wed" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="W"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_thu" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="T"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_fri" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="F"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_sat" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="S"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_sun" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="S"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Reminders toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/colorCard"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_blue"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        android:contentDescription="@null"
                        app:tint="@color/colorBlueIcon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reminders"
                        android:textColor="@color/colorTextPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get notified at 09:00 AM"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="12sp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_reminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/switch_track_tint"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Save Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp"
        android:paddingTop="12dp"
        android:background="@color/colorAppBg">

        <TextView
            android:id="@+id/btn_save_habit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="Save Habit"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>



