<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp">

        <FrameLayout
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/bg_notif_btn">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="@null"
                app:tint="@color/colorTextSecondary"/>
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Add New Habit"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <View android:layout_width="40dp" android:layout_height="40dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false"
        android:clipToPadding="false"
        android:paddingBottom="100dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <!-- Habit Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HABIT NAME"
                android:textColor="#9495c7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_habit_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_card_dark"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="e.g. Morning Meditation"
                android:textColor="@color/white"
                android:textColorHint="#9495c7"
                android:textSize="15sp"
                android:inputType="text"
                android:layout_marginBottom="24dp"/>

            <!-- Description -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DESCRIPTION / GOAL"
                android:textColor="#9495c7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_habit_description"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_card_dark"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:hint="e.g. 15 minutes, 2 Liters"
                android:textColor="@color/white"
                android:textColorHint="#9495c7"
                android:textSize="15sp"
                android:inputType="text"
                android:layout_marginBottom="24dp"/>

            <!-- Icon Color Picker -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ICON COLOR"
                android:textColor="#9495c7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:id="@+id/color_indigo"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_habit_icon_indigo"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="10dp">
                    <View
                        android:id="@+id/color_indigo_check"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_day_chip_active"
                        android:visibility="visible"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/color_emerald"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_habit_icon_emerald"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="10dp">
                    <View
                        android:id="@+id/color_emerald_check"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_day_chip_active"
                        android:visibility="gone"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/color_pink"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_habit_icon_pink"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="10dp">
                    <View
                        android:id="@+id/color_pink_check"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_day_chip_active"
                        android:visibility="gone"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/color_orange"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_habit_icon_orange"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginEnd="10dp">
                    <View
                        android:id="@+id/color_orange_check"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_day_chip_active"
                        android:visibility="gone"/>
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/color_primary"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_habit_icon_primary"
                    android:clickable="true"
                    android:focusable="true">
                    <View
                        android:id="@+id/color_primary_check"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_day_chip_active"
                        android:visibility="gone"/>
                </FrameLayout>
            </LinearLayout>

            <!-- Frequency -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FREQUENCY"
                android:textColor="#9495c7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_card_dark"
                android:padding="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:id="@+id/freq_daily"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Daily"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_btn_primary"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/freq_weekly"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Weekly"
                    android:textColor="#9495c7"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp"/>

                <TextView
                    android:id="@+id/freq_specific"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Specific"
                    android:textColor="#9495c7"
                    android:textSize="13sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <!-- Active Days (show only for daily/specific) -->
            <LinearLayout
                android:id="@+id/active_days_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <TextView android:id="@+id/day_mon" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="M"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_tue" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="T"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_wed" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="W"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_thu" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="T"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_fri" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="F"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_sat" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="S"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active" android:layout_marginEnd="4dp"
                    android:clickable="true" android:focusable="true"/>
                <TextView android:id="@+id/day_sun" android:layout_width="0dp" android:layout_height="42dp"
                    android:layout_weight="1" android:gravity="center" android:text="S"
                    android:textColor="@color/white" android:textSize="13sp" android:textStyle="bold"
                    android:background="@drawable/bg_day_chip_active"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Reminders toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_blue"
                    android:layout_marginEnd="14dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        android:contentDescription="@null"
                        app:tint="@color/colorBlueIcon"/>
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reminders"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Get notified at 09:00 AM"
                        android:textColor="#9495c7"
                        android:textSize="12sp"/>
                </LinearLayout>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_reminder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/switch_track_tint"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Save Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp"
        android:paddingTop="12dp"
        android:background="@color/background_dark">

        <TextView
            android:id="@+id/btn_save_habit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="Save Habit"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>


