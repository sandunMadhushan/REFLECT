<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark">

    <!-- ── Scrollable body ── -->
    <ScrollView
        android:id="@+id/scroll_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_bar"
        android:scrollbars="none"
        android:fillViewport="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── TOP APP BAR ── -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="48dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="@color/text_primary_dark"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/add_habit_title"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <TextView
                    android:id="@+id/tv_toolbar_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/add_habit_title"
                    android:textColor="@color/text_primary_dark"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    app:layout_constraintStart_toEndOf="@id/btn_back"
                    app:layout_constraintEnd_toStartOf="@id/btn_more"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageView
                    android:id="@+id/btn_more"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_more_vert"
                    app:tint="@color/text_secondary_dark"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="@string/add_habit_title"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ── BODY ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- ── HABIT NAME section ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_habit_label_name"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Habit name input -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_dark"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:layout_marginBottom="28dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/text_secondary_dark"
                        android:contentDescription="@null"
                        android:layout_marginEnd="12dp" />

                    <EditText
                        android:id="@+id/et_habit_name"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="@string/add_habit_hint_name"
                        android:textColorHint="@color/text_secondary_dark"
                        android:textColor="@color/text_primary_dark"
                        android:textSize="15sp"
                        android:background="@android:color/transparent"
                        android:importantForAutofill="no"
                        android:inputType="textCapWords"
                        android:maxLines="1"
                        android:imeOptions="actionDone" />
                </LinearLayout>

                <!-- ── FREQUENCY section ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_habit_label_frequency"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Daily / Weekly / Specific pill tabs -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_freq_container"
                    android:padding="4dp"
                    android:layout_marginBottom="18dp">

                    <TextView
                        android:id="@+id/tab_daily"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/add_habit_freq_daily"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_freq_tab_active"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tab_weekly"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/add_habit_freq_weekly"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/tab_specific"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/add_habit_freq_specific"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- ── Day-of-week circles: M T W T F S S ── -->
                <LinearLayout
                    android:id="@+id/ll_days"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:weightSum="7"
                    android:layout_marginBottom="32dp">

                    <TextView
                        android:id="@+id/day_mon"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_mon"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_active"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/day_tue"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_tue"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/day_wed"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_wed"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_active"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/day_thu"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_thu"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_active"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/day_fri"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_fri"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/day_sat"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_sat"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_inactive"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="5dp" />

                    <TextView
                        android:id="@+id/day_sun"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="@string/add_habit_day_sun"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_day_circle_inactive"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <!-- ── LINK TO GOAL section ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_habit_label_link_goal"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp" />

                <!-- Goal selector row -->
                <LinearLayout
                    android:id="@+id/ll_goal_selector"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_input_dark"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_flag"
                        app:tint="@color/text_secondary_dark"
                        android:contentDescription="@null"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:id="@+id/tv_selected_goal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/add_habit_select_goal"
                        android:textColor="@color/text_secondary_dark"
                        android:textSize="15sp" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_expand_more"
                        app:tint="@color/text_secondary_dark"
                        android:contentDescription="@null" />
                </LinearLayout>

                <!-- Goal tip text -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/add_habit_goal_tip"
                    android:textColor="@color/text_secondary_dark"
                    android:textSize="12sp"
                    android:layout_marginBottom="28dp" />

                <!-- ── REMINDERS card ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_reminder_card"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <!-- Orange bell circle -->
                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_bell_circle"
                        android:layout_marginEnd="14dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_notifications"
                            app:tint="@color/white"
                            android:contentDescription="@null" />
                    </FrameLayout>

                    <!-- Title + subtitle -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_habit_reminders"
                            android:textColor="@color/text_primary_dark"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_reminder_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/add_habit_reminder_sub"
                            android:textColor="@color/text_secondary_dark"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- Material blue toggle switch -->
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_reminder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:showText="false"
                        app:thumbTint="@color/white"
                        app:trackTint="@color/primary" />
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ── SAVE HABIT button pinned to bottom ── -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="32dp"
        android:background="@color/background_dark"
        android:layout_alignParentBottom="true">

        <Button
            android:id="@+id/btn_save_habit"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/add_habit_save"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:drawableStart="@drawable/ic_check_circle"
            android:drawablePadding="10dp"
            android:background="@drawable/bg_btn_save_habit"
            android:stateListAnimator="@null"
             />
    </LinearLayout>

</RelativeLayout>
