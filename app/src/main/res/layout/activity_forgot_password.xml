<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorAppBg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top spacer -->
        <Space android:layout_width="match_parent" android:layout_height="40dp" />

        <!-- ===== HEADER ===== -->

        <!-- Logo -->
        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center_horizontal"
            android:elevation="8dp"
            android:src="@drawable/reflect_logo"
            android:scaleType="centerCrop"
            android:contentDescription="@string/content_desc_logo"
            app:shapeAppearanceOverlay="@style/RoundedLogoShape"
            app:strokeColor="#33FFFFFF"
            app:strokeWidth="1.5dp" />

        <Space android:layout_width="match_parent" android:layout_height="20dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:fontFamily="sans-serif"
            android:letterSpacing="-0.02"
            android:text="@string/forgot_password_title"
            android:textColor="@color/colorTextPrimary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="8dp" />

        <!-- Subtitle -->
        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:text="@string/forgot_password_subtitle"
            android:textColor="@color/colorTextSecondary"
            android:textSize="14sp" />

        <Space android:layout_width="match_parent" android:layout_height="8dp" />

        <!-- Step indicator -->
        <TextView
            android:id="@+id/tv_step"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_badge_white_alpha"
            android:paddingStart="14dp"
            android:paddingTop="5dp"
            android:paddingEnd="14dp"
            android:paddingBottom="5dp"
            android:text="@string/forgot_step_email"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="28dp" />

        <!-- ===== STEP 1: EMAIL FORM ===== -->
        <LinearLayout
            android:id="@+id/layout_step1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_email"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/primary"
                app:endIconDrawable="@drawable/ic_email"
                app:endIconMode="custom"
                app:hintTextColor="@color/primary"
                app:startIconTint="@color/colorTextSecondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_email"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="match_parent" android:layout_height="20dp" />

            <!-- Find Account Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_find_account"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_login"
                android:text="@string/btn_find_account"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="end"
                app:iconTint="@color/white" />

        </LinearLayout>

        <!-- ===== STEP 2: NEW PASSWORD FORM ===== -->
        <LinearLayout
            android:id="@+id/layout_step2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Email display (read-only) -->
            <TextView
                android:id="@+id/tv_found_email"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_card_white"
                android:gravity="center"
                android:padding="14dp"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp" />

            <!-- New Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_new_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_new_password"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/primary"
                app:endIconMode="password_toggle"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_new_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="textPassword"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="match_parent" android:layout_height="16dp" />

            <!-- Confirm New Password -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_confirm_password"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/hint_confirm_new_password"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxStrokeColor="@color/primary"
                app:endIconMode="password_toggle"
                app:hintTextColor="@color/primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_confirm_password"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:inputType="textPassword"
                    android:textColor="@color/colorTextPrimary"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <Space android:layout_width="match_parent" android:layout_height="20dp" />

            <!-- Reset Password Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reset_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_login"
                android:text="@string/btn_reset_password"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_arrow_forward"
                app:iconGravity="end"
                app:iconTint="@color/white" />

        </LinearLayout>

        <!-- ===== STEP 3: SUCCESS ===== -->
        <LinearLayout
            android:id="@+id/layout_success"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Success icon circle -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_circle_green">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/forgot_success_title"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/colorGreenIcon" />
            </FrameLayout>

            <Space android:layout_width="match_parent" android:layout_height="20dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.02"
                android:text="@string/forgot_success_title"
                android:textColor="@color/colorTextPrimary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <Space android:layout_width="match_parent" android:layout_height="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/forgot_success_subtitle"
                android:textColor="@color/colorTextSecondary"
                android:textSize="14sp" />

            <Space android:layout_width="match_parent" android:layout_height="28dp" />

            <!-- Go to Login Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_go_to_login"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_login"
                android:text="@string/btn_go_to_login"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <Space android:layout_width="match_parent" android:layout_height="28dp" />

        <!-- Back to Login link -->
        <TextView
            android:id="@+id/tv_back_to_login"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:clickable="true"
            android:focusable="true"
            android:text="@string/forgot_back_to_login"
            android:textColor="@color/primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <Space android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>

