<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingBottom="102dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== TOP APP BAR ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="48dp"
                android:paddingBottom="12dp">

                <!-- Avatar + greeting -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Avatar circle with border -->
                    <FrameLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp">
                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_avatar_border"
                            android:padding="2dp"
                            android:src="@drawable/bg_avatar_placeholder"
                            android:scaleType="centerCrop" />
                        <!-- Initials label -->
                        <TextView
                            android:id="@+id/tv_avatar_initials"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_avatar_placeholder"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_welcome"
                            android:textColor="@color/text_secondary_light"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tv_user_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary_light"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Notification button -->
                <FrameLayout
                    android:id="@+id/btn_notifications"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_notif_btn"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_notifications"
                        app:tint="@color/text_secondary_light"/>
                    <!-- Red dot -->
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:layout_gravity="top|end"
                        android:layout_marginTop="6dp"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_notif_dot"/>
                </FrameLayout>
            </LinearLayout>

            <!-- ===== CONTENT PADDING ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- ===== STATS ROW ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp"
                    android:baselineAligned="false">

                    <!-- Active Goals card (primary gradient) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:background="@drawable/bg_card_primary"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:elevation="4dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_icon_white_alpha">
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_flag"
                                    app:tint="@color/white"/>
                            </FrameLayout>
                            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/bg_badge_white_alpha"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:text="@string/home_this_week"
                                android:textColor="@color/white"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <Space android:layout_width="1dp" android:layout_height="12dp"/>

                        <TextView
                            android:id="@+id/tv_active_goals_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="32sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_active_goals"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Right column: Completed + Habits -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:orientation="vertical">

                        <!-- Completed -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_white"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp"
                            android:elevation="2dp"
                            android:layout_marginBottom="8dp">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tv_completed_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12"
                                    android:textColor="@color/text_primary_light"
                                    android:textSize="24sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_completed"
                                    android:textColor="@color/text_secondary_light"
                                    android:textSize="11sp"/>
                            </LinearLayout>
                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:background="@drawable/bg_circle_green">
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check_circle"
                                    app:tint="@color/green_icon"/>
                            </FrameLayout>
                        </LinearLayout>

                        <!-- Today's Habits -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_card_white"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="14dp"
                            android:elevation="2dp">
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:id="@+id/tv_habits_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="5/8"
                                    android:textColor="@color/text_primary_light"
                                    android:textSize="24sp"
                                    android:textStyle="bold"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/home_habits_today"
                                    android:textColor="@color/text_secondary_light"
                                    android:textSize="11sp"/>
                            </LinearLayout>
                            <!-- Circular progress (custom view via canvas) -->
                            <me.madhushan.reflect.ui.CircularProgressView
                                android:id="@+id/circular_progress"
                                android:layout_width="40dp"
                                android:layout_height="40dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== MOTIVATIONAL QUOTE CARD ===== -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginBottom="24dp"
                    android:background="@drawable/bg_quote_card"
                    android:elevation="4dp">

                    <!-- Gradient overlay -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_quote_overlay"/>

                    <!-- Text content -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_white_alpha"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:text="@string/home_daily_inspiration"
                            android:textColor="@color/white"
                            android:textSize="10sp"
                            android:textAllCaps="true"
                            android:textStyle="bold"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tv_quote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/home_quote"
                            android:textColor="@color/white"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="4dp"/>
                        <TextView
                            android:id="@+id/tv_quote_author"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_quote_author"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </FrameLayout>

                <!-- ===== PROGRESS SECTION ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/home_your_progress"
                        android:textColor="@color/text_primary_light"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_view_all"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Bar Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="24dp">

                    <!-- Bars -->
                    <LinearLayout
                        android:id="@+id/chart_bars"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:orientation="horizontal"
                        android:gravity="bottom"
                        android:baselineAligned="false">

                        <!-- Mon -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_mon" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_bar_inactive" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                        <!-- Tue -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_tue" android:layout_width="match_parent" android:layout_height="78dp" android:background="@drawable/bg_bar_inactive" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                        <!-- Wed -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_wed" android:layout_width="match_parent" android:layout_height="60dp" android:background="@drawable/bg_bar_active_light" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                        <!-- Thu -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_thu" android:layout_width="match_parent" android:layout_height="96dp" android:background="@drawable/bg_bar_inactive" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                        <!-- Fri (today - active) -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_fri" android:layout_width="match_parent" android:layout_height="114dp" android:background="@drawable/bg_bar_active" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                        <!-- Sat -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_sat" android:layout_width="match_parent" android:layout_height="72dp" android:background="@drawable/bg_bar_inactive" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                        <!-- Sun -->
                        <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="bottom|center_horizontal">
                            <View android:id="@+id/bar_sun" android:layout_width="match_parent" android:layout_height="90dp" android:background="@drawable/bg_bar_inactive" android:layout_marginStart="2dp" android:layout_marginEnd="2dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Day Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Mon" android:textColor="@color/text_hint" android:textSize="11sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Tue" android:textColor="@color/text_hint" android:textSize="11sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Wed" android:textColor="@color/text_hint" android:textSize="11sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Thu" android:textColor="@color/text_hint" android:textSize="11sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Fri" android:textColor="@color/primary" android:textSize="11sp" android:textStyle="bold"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sat" android:textColor="@color/text_hint" android:textSize="11sp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Sun" android:textColor="@color/text_hint" android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ===== RECENT ACTIVITY ===== -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_recent_activity"
                    android:textColor="@color/text_primary_light"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <!-- Activity item 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="10dp">
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_blue">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_mindfulness"
                            app:tint="@color/blue_icon"/>
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_activity_water"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_activity_water_sub"
                            android:textColor="@color/text_secondary_light"
                            android:textSize="11sp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_xp"
                        android:textColor="@color/primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Activity item 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="14dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="16dp">
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_purple">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_journal"
                            app:tint="@color/purple_icon"/>
                    </FrameLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_activity_reflection"
                            android:textColor="@color/text_primary_light"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/home_activity_reflection_sub"
                            android:textColor="@color/text_secondary_light"
                            android:textSize="11sp"/>
                    </LinearLayout>
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_arrow_forward"
                        app:tint="@color/text_hint"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- ===== BOTTOM NAVIGATION CONTAINER ===== -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="102dp"
        android:layout_gravity="bottom">

        <!-- Nav bar background (sits at bottom) -->
        <LinearLayout
            android:id="@+id/bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_gravity="bottom"
            android:background="@drawable/bg_bottom_nav_curved"
            android:orientation="horizontal"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:elevation="8dp">

            <!-- Home (active) -->
            <LinearLayout
                android:id="@+id/nav_home"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    app:tint="@color/primary"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_nav_home"
                    android:textColor="@color/primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Goals -->
            <LinearLayout
                android:id="@+id/nav_goals"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_goals"
                    app:tint="@color/text_hint"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_nav_goals"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Center spacer for FAB -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"/>

            <!-- Journal -->
            <LinearLayout
                android:id="@+id/nav_journal"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_journal"
                    app:tint="@color/text_hint"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_nav_journal"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>

            <!-- Profile -->
            <LinearLayout
                android:id="@+id/nav_profile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    app:tint="@color/text_hint"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_nav_profile"
                    android:textColor="@color/text_hint"
                    android:textSize="10sp"
                    android:layout_marginTop="3dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- FAB Add button — floats above the nav bar at center -->
        <FrameLayout
            android:id="@+id/nav_add"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="top|center_horizontal"
            android:background="@drawable/bg_fab_primary"
            android:elevation="16dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_add"
                app:tint="@color/white"/>
        </FrameLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

