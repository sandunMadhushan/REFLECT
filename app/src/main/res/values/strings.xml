    <string name="help_title">Help &amp; Support</string>
    <string name="help_hero_title">How can we help?</string>
    <string name="help_hero_sub">Find answers to common questions or reach out to our support team.</string>
    <string name="help_section_faq">Frequently Asked Questions</string>
    <string name="help_faq1_q">How do I add a new goal?</string>
    <string name="help_faq1_a">Tap the ＋ button on the Home screen or navigate to the Goals tab and tap "Add Goal". Give your goal a title and description, then tap Save.</string>
    <string name="help_faq2_q">How do I write a reflection?</string>
    <string name="help_faq2_a">Open any goal from the Goals tab, then tap "Add Reflection" at the bottom. Write your thoughts and tap Save. Your reflections are stored privately and only visible to you.</string>
    <string name="help_faq3_q">Is my data stored securely?</string>
    <string name="help_faq3_a">Yes. All your data is stored locally on your device using an encrypted Room database. Your passwords are hashed with SHA-256 — we never store plain-text passwords.</string>
    <string name="help_faq4_q">How do I change my password?</string>
    <string name="help_faq4_a">Go to Profile → Personal Details → Change Password section. Enter your current password and your new password, then tap Save Changes.</string>
