<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required for push notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required to load Google profile photos via Glide -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Camera for capturing profile photo -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Gallery access — Android 13+ uses READ_MEDIA_IMAGES, older uses READ_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Add camera feature for permission compliance -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />

    <application
        android:name=".ReflectApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.REFLECT">

        <!-- Splash Screen - LAUNCHER -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.REFLECT.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Register Screen -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Onboarding Screen -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false" />

        <!-- Forgot Password Screen -->
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Profile Screen -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- Main / Home Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Personal Details Screen -->
        <activity
            android:name=".PersonalDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Subscription Screen -->
        <activity
            android:name=".SubscriptionActivity"
            android:exported="false" />

        <!-- Help & Support Screen -->
        <activity
            android:name=".HelpSupportActivity"
            android:exported="false" />

        <!-- Goals List Screen -->
        <activity
            android:name=".GoalsActivity"
            android:exported="false" />

        <!-- Add Goal Screen -->
        <activity
            android:name=".AddGoalActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Goal Details Screen -->
        <activity
            android:name=".GoalDetailsActivity"
            android:exported="false" />

        <!-- Edit Goal Screen -->
        <activity
            android:name=".EditGoalActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Add Reflection Screen -->
        <activity
            android:name=".AddReflectionActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Reflection Journal Screen -->
        <activity
            android:name=".ReflectionJournalActivity"
            android:exported="false" />

        <!-- Habit Tracker Screen -->
        <activity
            android:name=".HabitTrackerActivity"
            android:exported="false" />

        <!-- Add Habit Screen -->
        <activity
            android:name=".AddHabitActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Achievements Screen -->
        <activity
            android:name=".AchievementsActivity"
            android:exported="false" />

        <!-- Notifications Screen -->
        <activity
            android:name=".NotificationsActivity"
            android:exported="false" />

        <!-- Progress Analytics Screen -->
        <activity
            android:name=".ProgressAnalyticsActivity"
            android:exported="false" />

        <!-- Vision Board Screen -->
        <activity
            android:name=".VisionBoardActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- Add / Edit Vision Board Item -->
        <activity
            android:name=".AddVisionItemActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <!-- Facebook Login — App ID and Client Token (replace values with yours from developers.facebook.com) -->
        <meta-data
            android:name="com.facebook.sdk.ApplicationId"
            android:value="@string/facebook_app_id" />
        <meta-data
            android:name="com.facebook.sdk.ClientToken"
            android:value="@string/facebook_client_token" />

        <!-- Facebook Login Activity (required by Facebook SDK) -->
        <activity
            android:name="com.facebook.FacebookActivity"
            android:configChanges="keyboard|keyboardHidden|screenLayout|screenSize|orientation" />

        <!-- Facebook Custom Tab Activity (required for SDK 13+) -->
        <activity
            android:name="com.facebook.CustomTabActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="@string/fb_login_protocol_scheme"
                    tools:ignore="AppLinkUrlError" />
            </intent-filter>
        </activity>

        <!-- FileProvider for camera capture temp files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>