<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:name=".ReflectApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.REFLECT">

        <!-- Splash Screen - LAUNCHER -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.REFLECT.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Register Screen -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Onboarding Screen -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false" />

        <!-- Forgot Password Screen -->
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Profile Screen -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- Main / Home Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Personal Details Screen -->
        <activity
            android:name=".PersonalDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Subscription Screen -->
        <activity
            android:name=".SubscriptionActivity"
            android:exported="false" />

        <!-- Help & Support Screen -->
        <activity
            android:name=".HelpSupportActivity"
            android:exported="false" />
    </application>

</manifest>