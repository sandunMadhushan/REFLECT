<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required for push notifications on Android 13+ -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Required to load Google profile photos via Glide -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Camera for capturing profile photo -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Gallery access — Android 13+ uses READ_MEDIA_IMAGES, older uses READ_EXTERNAL_STORAGE -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name=".ReflectApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.REFLECT">

        <!-- Splash Screen - LAUNCHER -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.REFLECT.Splash"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Screen -->
        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Register Screen -->
        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Onboarding Screen -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false" />

        <!-- Forgot Password Screen -->
        <activity
            android:name=".ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Profile Screen -->
        <activity
            android:name=".ProfileActivity"
            android:exported="false" />

        <!-- Main / Home Screen -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <!-- Personal Details Screen -->
        <activity
            android:name=".PersonalDetailsActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Subscription Screen -->
        <activity
            android:name=".SubscriptionActivity"
            android:exported="false" />

        <!-- Help & Support Screen -->
        <activity
            android:name=".HelpSupportActivity"
            android:exported="false" />

        <!-- Goals List Screen -->
        <activity
            android:name=".GoalsActivity"
            android:exported="false" />

        <!-- Add Goal Screen -->
        <activity
            android:name=".AddGoalActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Goal Details Screen -->
        <activity
            android:name=".GoalDetailsActivity"
            android:exported="false" />

        <!-- Edit Goal Screen -->
        <activity
            android:name=".EditGoalActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Add Reflection Screen -->
        <activity
            android:name=".AddReflectionActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Reflection Journal Screen -->
        <activity
            android:name=".ReflectionJournalActivity"
            android:exported="false" />

        <!-- Habit Tracker Screen -->
        <activity
            android:name=".HabitTrackerActivity"
            android:exported="false" />

        <!-- Add Habit Screen -->
        <activity
            android:name=".AddHabitActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- FileProvider for camera capture temp files -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>