# ─────────────────────────────────────────────────────────────────────────────
# REFLECT — Secret Keys Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to local.properties and fill in your real values.
# local.properties is gitignored — your keys will NEVER be committed to GitHub.
#
# DO NOT rename this file to local.properties — keep it as an example template.
# ─────────────────────────────────────────────────────────────────────────────

# Android SDK path (Android Studio sets this automatically)
sdk.dir=/path/to/your/android/sdk

# ── Google Sign-In ────────────────────────────────────────────────────────────
# Firebase Console → Project Settings → General → Web Client ID
# OR Google Cloud Console → Credentials → OAuth 2.0 Client IDs → Web client
GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com

# ── Facebook Login ────────────────────────────────────────────────────────────
# https://developers.facebook.com → Your App → Settings → Basic
FACEBOOK_APP_ID=YOUR_FACEBOOK_APP_ID
# https://developers.facebook.com → Your App → Settings → Advanced → Client Token
FACEBOOK_CLIENT_TOKEN=YOUR_FACEBOOK_CLIENT_TOKEN

